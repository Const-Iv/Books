# Core runtime
APP_ENV=local
PORT=4100
QA_BACKEND_PORT=4100
QA_FRONTEND_PORT=3100
APP_DATA_DIR=runtime/data
APP_WORKSPACE_DIR=runtime/workspace
LOG_LEVEL=info

# Agent runner
CODEX_CLI_PATH=codex
CODEX_MODEL=
CODEX_SANDBOX=workspace-write
CODEX_EPHEMERAL=true
WORKER_MAX_PARALLEL=4
WORKER_TIMEOUT_MS=600000
WORKER_IDLE_KILL_MS=480000

# Example external integrations
API_BASE_URL=
API_TOKEN=
WEBHOOK_SECRET=

# Scheduler
SCHEDULER_ENABLED=true
DEFERRED_TASK_INTERVAL_MS=15000
WATCHDOG_INTERVAL_MS=1800000
